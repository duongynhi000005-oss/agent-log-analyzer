{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/robertdouglass/claude-log-analyzer/kitty-specs/top-20-sdd-fingerprint-registry-01KRZEQ3/contracts/sdd-detector.schema.json",
  "title": "SDDDetector",
  "description": "Registry record describing how to identify one named spec-driven-development (SDD) tool. Stored as elements of internal/analyzer/signatures/sdd_detectors.json.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "display_name", "category", "competitor_priority", "status", "source_references", "markers", "confidence_rules"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{2,}$",
        "description": "Allowlisted public identifier. Snake-case."
      },
      "display_name": { "type": "string", "minLength": 1 },
      "aliases": { "type": "array", "items": { "type": "string" }, "default": [] },
      "category": { "type": "string", "minLength": 1 },
      "competitor_priority": { "type": "integer", "minimum": 1 },
      "status": { "enum": ["verified", "research_needed", "blocked"] },
      "source_references": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "url"],
          "properties": {
            "kind": { "type": "string", "enum": ["official_repo", "docs", "release", "package_registry", "demo_fixture"] },
            "url": { "type": "string", "format": "uri" },
            "note": { "type": "string" }
          }
        }
      },
      "markers": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source_class"],
          "properties": {
            "source_class": {
              "enum": [
                "config_dir",
                "config_file",
                "package_manifest",
                "command_name",
                "slash_command",
                "mcp_server_name",
                "skill_name",
                "plugin_manifest",
                "cli_binary",
                "cli_version_probe"
              ]
            },
            "pattern": { "type": "string", "description": "Regex; required for non-CLI source classes." },
            "binary": { "type": "string", "description": "CLI binary name; required for cli_binary and cli_version_probe." },
            "version_args": { "type": "array", "items": { "type": "string" }, "default": ["--version"] },
            "negative": { "type": "boolean", "default": false },
            "note": { "type": "string" }
          },
          "allOf": [
            {
              "if": { "properties": { "source_class": { "enum": ["cli_binary", "cli_version_probe"] } } },
              "then": { "required": ["binary"] },
              "else": { "required": ["pattern"] }
            }
          ]
        }
      },
      "confidence_rules": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["confidence"],
          "properties": {
            "confidence": { "enum": ["high", "medium", "low"] },
            "requires_any_of": {
              "type": "array",
              "items": { "$ref": "#/items/properties/markers/items/properties/source_class" }
            },
            "requires_all_of": {
              "type": "array",
              "items": { "$ref": "#/items/properties/markers/items/properties/source_class" }
            },
            "requires_distinct_classes": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "allOf": [
      {
        "if": { "properties": { "status": { "const": "verified" } } },
        "then": { "properties": { "source_references": { "minItems": 1 } } }
      }
    ]
  }
}
